{
  "name": "mecxer713/bgfi-payment",
  "description": "Laravel SDK for integrating the BGFI RDC payment gateway",
  "license": "MIT",
  "homepage": "https://github.com/mecxer713/bgfi-payment",
  "support": {
    "issues": "https://github.com/mecxer713/bgfi-payment/issues",
    "source": "https://github.com/mecxer713/bgfi-payment",
    "docs": "https://github.com/mecxer713/bgfi-payment#readme"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mecxer713"
    }
  ],
  "authors": [
    {
      "name": "Mecxer713",
      "email": "mecxer@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.8",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/filesystem": "^10.0|^11.0|^12.0",
    "symfony/config": "^7.4",
    "symfony/dependency-injection": "^7.4",
    "symfony/http-kernel": "^7.4",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "psr/simple-cache": "^3.0",
    "symfony/cache": "^7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "orchestra/testbench": "^8.0|^9.0"
  },
  "autoload": {
    "psr-4": {
      "Mecxer713\\BgfiPayment\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Mecxer713\\BgfiPayment\\BgfiPaymentServiceProvider"
      ],
      "aliases": {
        "BgfiPayment": "Mecxer713\\BgfiPayment\\Facades\\BgfiPayment"
      }
    }
  },
  "type": "library",
  "keywords": [
    "bgfi",
    "omnitech",
    "payment",
    "laravel",
    "rdc"
  ],
  "scripts": {
    "test": "phpunit"
  },
  "autoload-dev": {
    "psr-4": {
      "Mecxer713\\BgfiPayment\\Tests\\": "tests/"
    }
  }
}
